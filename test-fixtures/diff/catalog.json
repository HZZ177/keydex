{
  "schema_version": 1,
  "fixtures": [
    {
      "id": "standard-modified",
      "format": "unified_patch",
      "payload": {
        "patch": "diff --git a/src/example.ts b/src/example.ts\nindex 1111111..2222222 100644\n--- a/src/example.ts\n+++ b/src/example.ts\n@@ -1,2 +1,2 @@\n-const value = 1;\n+const value = 2;\n export default value;\n"
      },
      "expected": {
        "file_count": 1,
        "statuses": ["modified"],
        "additions": 1,
        "deletions": 1,
        "diagnostics": []
      }
    },
    {
      "id": "relaxed-apply-patch",
      "format": "apply_patch",
      "payload": {
        "patch": "*** Begin Patch\n*** Update File: src/app.py\n@@\n-print('old')\n+print('new')\n*** End Patch"
      },
      "expected": {
        "file_count": 1,
        "statuses": ["modified"],
        "additions": 1,
        "deletions": 1,
        "diagnostics": ["approximate_hunk"]
      }
    },
    {
      "id": "multi-file",
      "format": "unified_patch",
      "payload": {
        "patch": "diff --git a/src/a.ts b/src/a.ts\n--- a/src/a.ts\n+++ b/src/a.ts\n@@ -1 +1 @@\n-a\n+A\ndiff --git a/src/b.ts b/src/b.ts\n--- a/src/b.ts\n+++ b/src/b.ts\n@@ -1 +1,2 @@\n b\n+B\n"
      },
      "expected": {
        "file_count": 2,
        "statuses": ["modified", "modified"],
        "additions": 2,
        "deletions": 1,
        "diagnostics": []
      }
    },
    {
      "id": "content-only-added",
      "format": "content_only",
      "payload": {
        "path": "docs/new.md",
        "content": "# 新文档\n\n正文\n",
        "status": "added"
      },
      "expected": {
        "file_count": 1,
        "statuses": ["added"],
        "additions": 3,
        "deletions": 0,
        "diagnostics": ["content_synthesized"]
      }
    },
    {
      "id": "rename-with-edit",
      "format": "unified_patch",
      "payload": {
        "patch": "diff --git a/src/old name.ts b/src/new name.ts\nsimilarity index 80%\nrename from src/old name.ts\nrename to src/new name.ts\n--- a/src/old name.ts\n+++ b/src/new name.ts\n@@ -1 +1 @@\n-old\n+new\n"
      },
      "expected": {
        "file_count": 1,
        "statuses": ["renamed"],
        "additions": 1,
        "deletions": 1,
        "diagnostics": []
      }
    },
    {
      "id": "mode-only",
      "format": "unified_patch",
      "payload": {
        "patch": "diff --git a/scripts/run.sh b/scripts/run.sh\nold mode 100644\nnew mode 100755\n"
      },
      "expected": {
        "file_count": 1,
        "statuses": ["type_changed"],
        "additions": 0,
        "deletions": 0,
        "diagnostics": []
      }
    },
    {
      "id": "binary-file",
      "format": "git_file",
      "payload": {
        "old_path": "assets/logo.png",
        "new_path": "assets/logo.png",
        "status": "modified",
        "binary": true,
        "truncated": false,
        "patch": "diff --git a/assets/logo.png b/assets/logo.png\nBinary files a/assets/logo.png and b/assets/logo.png differ\n"
      },
      "expected": {
        "file_count": 1,
        "statuses": ["modified"],
        "additions": 0,
        "deletions": 0,
        "diagnostics": ["binary"]
      }
    },
    {
      "id": "truncated-file",
      "format": "git_file",
      "payload": {
        "old_path": "src/large.ts",
        "new_path": "src/large.ts",
        "status": "modified",
        "binary": false,
        "truncated": true,
        "patch": "diff --git a/src/large.ts b/src/large.ts\n--- a/src/large.ts\n+++ b/src/large.ts\n@@ -1,100 +1,100 @@\n-line 1\n+line one\n"
      },
      "expected": {
        "file_count": 1,
        "statuses": ["modified"],
        "additions": 1,
        "deletions": 1,
        "diagnostics": ["truncated"]
      }
    },
    {
      "id": "unicode-path",
      "format": "unified_patch",
      "payload": {
        "patch": "diff --git a/文档/说明.md b/文档/说明.md\n--- a/文档/说明.md\n+++ b/文档/说明.md\n@@ -1 +1 @@\n-旧内容\n+新内容\n"
      },
      "expected": {
        "file_count": 1,
        "statuses": ["modified"],
        "additions": 1,
        "deletions": 1,
        "diagnostics": []
      }
    },
    {
      "id": "crlf-lines",
      "format": "unified_patch",
      "payload": {
        "patch": "diff --git a/src/windows.txt b/src/windows.txt\r\n--- a/src/windows.txt\r\n+++ b/src/windows.txt\r\n@@ -1 +1 @@\r\n-old\r\n+new\r\n"
      },
      "expected": {
        "file_count": 1,
        "statuses": ["modified"],
        "additions": 1,
        "deletions": 1,
        "diagnostics": []
      }
    },
    {
      "id": "no-newline-marker",
      "format": "unified_patch",
      "payload": {
        "patch": "diff --git a/src/no-newline.txt b/src/no-newline.txt\n--- a/src/no-newline.txt\n+++ b/src/no-newline.txt\n@@ -1 +1 @@\n-old\n\\ No newline at end of file\n+new\n\\ No newline at end of file\n"
      },
      "expected": {
        "file_count": 1,
        "statuses": ["modified"],
        "additions": 1,
        "deletions": 1,
        "diagnostics": ["no_newline"]
      }
    },
    {
      "id": "large-generated",
      "format": "generated_unified_patch",
      "payload": {
        "path": "src/generated-large.ts",
        "rows": 20000,
        "change_every": 4
      },
      "expected": {
        "file_count": 1,
        "statuses": ["modified"],
        "additions": 5000,
        "deletions": 5000,
        "diagnostics": []
      }
    },
    {
      "id": "unsafe-parent-path",
      "format": "unified_patch",
      "payload": {
        "patch": "diff --git a/../secret.txt b/../secret.txt\n--- a/../secret.txt\n+++ b/../secret.txt\n@@ -1 +1 @@\n-old\n+new\n"
      },
      "expected": {
        "file_count": 0,
        "statuses": [],
        "additions": 0,
        "deletions": 0,
        "diagnostics": ["unsafe_path"]
      }
    }
  ]
}
