{
  "name": "keydex",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "powershell.exe -ExecutionPolicy Bypass -File .\\scripts\\dev-start.ps1",
    "dev:backend": ".venv\\Scripts\\python.exe backend\\app\\main.py",
    "dev:frontend": "pnpm --dir desktop run dev",
    "lint:backend": ".venv\\Scripts\\python.exe -m ruff check .",
    "test:backend": ".venv\\Scripts\\python.exe -m pytest",
    "test:frontend": "pnpm --dir desktop run test",
    "test:e2e:smoke": "node .dev/e2e/playwright-smoke.mjs",
    "test:e2e:app-shell": "node .dev/e2e/app-shell-sessions.mjs",
    "test:e2e:settings": "node .dev/e2e/empty-input-settings.mjs",
    "test:e2e:stream": "node .dev/e2e/stream-markdown-scroll.mjs",
    "test:e2e:tools": "node .dev/e2e/tool-timeline.mjs",
    "test:e2e:command-runtime": "node .dev/e2e/command-runtime-real.mjs",
    "test:e2e:edit-progress": "node .dev/e2e/tool-edit-progress.mjs",
    "test:e2e:workspace": "node .dev/e2e/workspace-session-redesign.mjs",
    "test:e2e:recovery": "node .dev/e2e/error-cancel-history.mjs",
    "test:e2e:visual": "node .dev/e2e/visual-localization-audit.mjs",
    "test:e2e:settings-usage": "node .dev/e2e/settings-usage-redesign.mjs",
    "test:e2e:runtime-foundation": "pnpm run test:e2e:runtime:model-defaults && pnpm run test:e2e:runtime:extension-settings && pnpm run test:e2e:runtime:auto-title && pnpm run test:e2e:runtime:session-branch && pnpm run test:e2e:runtime:context-compression",
    "test:e2e:runtime:model-defaults": "node .dev/e2e/runtime-model-defaults.mjs",
    "test:e2e:runtime:extension-settings": "node .dev/e2e/runtime-extension-settings.mjs",
    "test:e2e:runtime:auto-title": "node .dev/e2e/runtime-auto-title.mjs",
    "test:e2e:runtime:session-branch": "node .dev/e2e/runtime-session-branch.mjs",
    "test:e2e:runtime:context-compression": "node .dev/e2e/runtime-context-compression.mjs",
    "test:e2e:mcp:harness": "node .dev/e2e/mcp-harness-selftest.mjs",
    "test:e2e:mcp:smoke": "node .dev/e2e/mcp-smoke.mjs",
    "build:frontend": "pnpm --dir desktop run build",
    "test": "pnpm run lint:backend && pnpm run test:backend && pnpm run test:frontend",
    "verify": "pnpm run test"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
