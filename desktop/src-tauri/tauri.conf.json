{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Keydex",
  "version": "0.1.0",
  "identifier": "com.keydex.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Keydex",
        "width": 1445,
        "height": 900,
        "center": true,
        "visible": false,
        "minWidth": 880,
        "minHeight": 620,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx"],
        "name": "Markdown",
        "description": "Markdown Document",
        "mimeType": "text/markdown",
        "role": "Editor",
        "rank": "Default"
      }
    ],
    "resources": ["binaries/agent-server"],
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERCRUYyNzI5QzExNUU2RDYKUldUVzVoWEJLU2Z2MjJNRGt0V0ZMeG55cFlLUDBzUlFlSlU5WmR0dXVoSE41WGRuSHN2QWR6MzAK",
      "endpoints": [
        "https://github.com/HZZ177/keydex/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
