{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Python Codex",
  "version": "0.1.0",
  "identifier": "local.python-codex.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Python Codex",
        "width": 1280,
        "height": 820,
        "minWidth": 880,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/agent-server"]
  }
}
